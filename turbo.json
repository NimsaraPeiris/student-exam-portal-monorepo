{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "deploy": {
      "dependsOn": ["build"] // Deploy must depend on build [cite: 58]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}