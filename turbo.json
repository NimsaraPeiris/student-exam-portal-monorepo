{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ]
    },
    "deploy": {
      "dependsOn": [
        "build"
      ],
      "cache": false,
      "env": [
        "CLOUDFLARE_API_TOKEN"
      ]
    }
  }
}